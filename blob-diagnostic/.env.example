# Target page. Hostname MUST be localhost/127.0.0.1 or in ALLOWED_HOSTS.
TARGET_URL=http://localhost:3000

# Comma-separated extra allowed hostnames. localhost + 127.0.0.1 always allowed.
ALLOWED_HOSTS=staging.exemplo.local

# Where artifacts (HAR, blobs, report, logs) get written.
OUTPUT_DIR=./out

# Navigation/idle timeout (ms).
TIMEOUT_MS=30000

# Save decoded blob bytes to disk (only fires on allowlisted origin).
SAVE_BLOBS=true
