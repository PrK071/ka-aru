    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
