# Copie para `.env` (gitignored) e preencha. Carregado automaticamente pelo
# tools/sakura_requisitor.py (e manga_dataset) se python-dotenv estiver instalado.

# ---------------------------------------------------------------------------
# Proxy do Sakura (browser + solver + HTTP usam o MESMO IP).
# ---------------------------------------------------------------------------
# Formatos aceitos:
#   http://usuario:senha@host:porta      (HTTP/HTTPS com auth)
#   socks5://usuario:senha@host:porta    (SOCKS5; obs: Chromium nao faz auth SOCKS)
#   host:porta                           (sem auth)
#   host:porta:usuario:senha             (atalho com auth)
#
# IMPORTANTE p/ furar o Cloudflare 1020:
#   - Use proxy RESIDENCIAL ou MOVEL. Datacenter (AWS/OVH/etc.) costuma ja vir
#     bloqueado pelo Cloudflare.
#   - O cf_clearance fica preso ao IP. Prefira IP "sticky"/sessao (mesmo IP por
#     alguns minutos), nao rotativo a cada request.
SAKURA_PROXY=

# ---------------------------------------------------------------------------
# Resolucao automatica de captcha (opcional). Sem isto, o Cloudflare e
# resolvido manualmente na janela do navegador.
# ---------------------------------------------------------------------------
# CapSolver (suporta cf_clearance via AntiCloudflareTask -> melhor p/ o 1020).
CAPSOLVER_API_KEY=

# 2captcha (apenas token Turnstile; nao resolve cf_clearance).
TWOCAPTCHA_API_KEY=
