# Copie para `.env` e preencha. Carregado automaticamente se python-dotenv
# estiver instalado (pip install python-dotenv). Senao, exporte como variaveis
# de ambiente manualmente.

# --- Hugging Face (obrigatorio no modo real) ---
# Token de ESCRITA: https://huggingface.co/settings/tokens (role "write")
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dataset publico destino, formato usuario/nome
HF_DATASET_REPO=seu-usuario/mangas-dataset
HF_REVISION=main

# --- Opcionais (tem defaults sensatos em config.py) ---
# MANGA_DB_PATH=mangas.db
# MANGA_TEMP_DIR=.tmp_images
# MANGA_REQUEST_TIMEOUT=30
# MANGA_MAX_RETRIES=3
# MANGA_RETRY_BACKOFF=2.0
# MANGA_USER_AGENT=Mozilla/5.0 ...
